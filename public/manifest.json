{
  "manifest_version": 3,
  "name": "My Own Wallet",
  "version": "1.0.0",
  "description": "A secure Web3 crypto wallet",
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "http://localhost:5000/*",
    "https://*.blockscout.com/*",
    "https://*.llamarpc.com/*",
    "https://*.publicnode.com/*",
    "https://1rpc.io/*",
    "https://api-holesky.etherscan.io/*",
    "https://api-optimistic.etherscan.io/*",
    "https://api-sepolia-optimistic.etherscan.io/*",
    "https://api-sepolia.arbiscan.io/*",
    "https://api-sepolia.basescan.org/*",
    "https://api-sepolia.etherscan.io/*",
    "https://api-testnet.bscscan.com/*",
    "https://api-testnet.ftmscan.com/*",
    "https://api-testnet.polygonscan.com/*",
    "https://api.arbiscan.io/*",
    "https://api.avax-test.network/*",
    "https://api.avax.network/*",
    "https://api.basescan.org/*",
    "https://api.bscscan.com/*",
    "https://api.coingecko.com/*",
    "https://api.cronoscan.com/*",
    "https://api.etherscan.io/*",
    "https://api.ftmscan.com/*",
    "https://api.polygonscan.com/*",
    "https://api.snowtrace.io/*",
    "https://arb1.arbitrum.io/*",
    "https://arbitrum.llamarpc.com/*",
    "https://base.llamarpc.com/*",
    "https://bsc-dataseed.binance.org/*",
    "https://bsc-dataseed1.binance.org/*",
    "https://bsc-dataseed2.binance.org/*",
    "https://cloudflare-eth.com/*",
    "https://cloudflare-ipfs.com/*",
    "https://data-seed-prebsc-1-s1.binance.org/*",
    "https://data-seed-prebsc-2-s1.binance.org/*",
    "https://eth.llamarpc.com/*",
    "https://evm.cronos.org/*",
    "https://explorer.linea.build/*",
    "https://gateway.pinata.cloud/*",
    "https://ipfs.io/*",
    "https://linea-sepolia.publicnode.com/*",
    "https://linea.publicnode.com/*",
    "https://localhost:5000/*",
    "https://mainnet.base.org/*",
    "https://mainnet.optimism.io/*",
    "https://optimism.llamarpc.com/*",
    "https://polygon.llamarpc.com/*",
    "https://rpc-mumbai.maticvigil.com/*",
    "https://rpc.ankr.com/*",
    "https://rpc.linea.build/*",
    "https://rpc.sepolia.linea.build/*",
    "https://rpc.testnet.fantom.network/*",
    "https://rpc2.sepolia.org/*",
    "https://rpcapi.fantom.network/*",
    "https://sepolia-rollup.arbitrum.io/*",
    "https://sepolia.base.org/*",
    "https://sepolia.gateway.tenderly.co/*",
    "https://sepolia.lineascan.build/*",
    "https://sepolia.optimism.io/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  }
}
