# ── API Keys ──────────────────────────────────────────
# Infura (optional — only needed for some swap/buy features)
# VITE_INFURE_API_KEY=your_infura_key_here

# Etherscan key — removes Activity tab rate limits (free at etherscan.io/apis)
# VITE_ETHERSCAN_KEY=YourKeyHere

# MongoDB backup API (start server: cd server && npm run dev)
VITE_API_URL=http://localhost:5000/api